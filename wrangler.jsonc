{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "samudra-aya",
  "compatibility_date": "2025-09-24",
  "compatibility_flags": ["nodejs_compat"],
  "main": "src/server.ts",

  // ── Secrets (set via: npx wrangler secret put GFW_TOKEN) ──────────────────
  // GFW_TOKEN  →  Global Fishing Watch API token

  // ── Preview environment (npx wrangler deploy --env preview) ──────────────
  "env": {
    "preview": {
      "name": "samudra-aya-preview"
    }
  }
}
